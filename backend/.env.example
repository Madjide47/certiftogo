# ─────────────────────────────────────────────────────────────
# Backend CertifTOGO — variables d'environnement
# Copiez ce fichier en `.env` et adaptez les valeurs.
# ─────────────────────────────────────────────────────────────

# Serveur
PORT=4000
NODE_ENV=development

# Connexion PostgreSQL
# Option A : URL de connexion complète (prioritaire si définie)
# DATABASE_URL=postgresql://certiftogo:certiftogo_dev@localhost:5432/certiftogo
# Option B : paramètres séparés
PGHOST=localhost
PGPORT=5432
PGDATABASE=certiftogo
PGUSER=certiftogo
PGPASSWORD=certiftogo_dev

# JWT
JWT_SECRET=changez_moi_par_une_chaine_longue_et_aleatoire
JWT_EXPIRES_IN=24h

# OTP
OTP_LENGTH=6
OTP_EXPIRATION_MINUTES=5

# ── Envoi WhatsApp (Meta Cloud API) ──────────────────────────
# "mock" (défaut) : le code OTP s'affiche dans la console du serveur,
#   aucun identifiant requis. "cloud" : envoi réel via l'API Meta.
WHATSAPP_MODE=mock
# Token d'accès permanent (System User) — SECRET, ne jamais versionner.
WHATSAPP_TOKEN=
# Identifiant du numéro expéditeur (dashboard Meta > WhatsApp > API Setup).
WHATSAPP_PHONE_NUMBER_ID=
# Template de catégorie "authentication" approuvé par Meta.
WHATSAPP_TEMPLATE_NOM=certiftogo_code_otp
WHATSAPP_TEMPLATE_LANGUE=fr
# "true" si le template comporte un bouton de copie du code.
WHATSAPP_AVEC_BOUTON=true

# CORS — origines autorisées (séparées par des virgules)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Certification (Phase 4)
# Secret de signature numérique du ministère (HMAC), 16 caractères minimum.
# Aucune valeur par défaut n'existe dans le code : en production, l'application
# REFUSE DE DÉMARRER si ce secret est absent ou trop court.
# Générer : node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MINISTERE_SIGNING_SECRET=
# Ancrage blockchain : "mock" (défaut, aucun nœud) ou "onchain" (Ethers réel).
BLOCKCHAIN_MODE=mock
# Contrat RegistreDiplomes déployé (voir blockchain/scripts/deploy.js).
CONTRAT_ADRESSE=
# Onchain : URL RPC (nœud Hardhat local ou Polygon Amoy) + clé du signataire autorisé.
BLOCKCHAIN_RPC_URL=http://127.0.0.1:8545
BLOCKCHAIN_PRIVATE_KEY=
# URL publique du backend (liens vers PDF / QR générés).
PUBLIC_BASE_URL=http://localhost:4000
# URL publique de vérification (encodée dans les QR codes).
PUBLIC_VERIFY_URL=http://localhost:5174/verifier
