# ─────────────────────────────────────────────────────────────
# Variables d'environnement racine (référence globale du projet)
# Copiez ce fichier en `.env` et adaptez les valeurs.
# Chaque sous-projet (backend, frontend) possède aussi son propre .env.example
# ─────────────────────────────────────────────────────────────

# Base de données PostgreSQL partagée
POSTGRES_DB=certiftogo
POSTGRES_USER=certiftogo
POSTGRES_PASSWORD=certiftogo_dev
POSTGRES_PORT=5432
