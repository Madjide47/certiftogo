# ── Configuration blockchain CertifTOGO ──────────────────────────
# Copier ce fichier en `.env` et renseigner les valeurs. NE JAMAIS commiter `.env`.

# URL RPC du testnet Polygon Amoy (public par défaut, ou Alchemy/Infura)
AMOY_RPC_URL=https://rpc-amoy.polygon.technology

# Clé privée du compte de déploiement (compte de test uniquement, alimenté en POL de test)
# Obtenir des POL de test : https://faucet.polygon.technology (réseau Amoy)
DEPLOYER_PRIVATE_KEY=

# Clé API PolygonScan (pour vérifier le contrat sur l'explorer — optionnel)
POLYGONSCAN_API_KEY=
